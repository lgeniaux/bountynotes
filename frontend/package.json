{
  "name": "frontend",
  "version": "0.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\" \"*.{json,md}\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "20.3.17",
    "@angular/compiler": "20.3.17",
    "@angular/core": "20.3.17",
    "@angular/forms": "20.3.17",
    "@angular/platform-browser": "20.3.17",
    "@angular/router": "20.3.17",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.3.17",
    "@angular/cli": "20.3.17",
    "@angular/compiler-cli": "20.3.17",
    "@types/jasmine": "5.1.12",
    "jasmine-core": "5.9.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "prettier": "3.6.2",
    "typescript": "5.9.2"
  }
}
